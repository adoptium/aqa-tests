<project name="MBCS_Tests/codepoint" default="build" basedir="." xmlns:if="ant:if">
	<description>
	MBCS_Tests/codepoint
        </description>

	<import file="${TEST_ROOT}/functional/MBCS_Tests/buildDependencies.xml"/>
	
	<!-- Import getDependencies.xml to enable downloading Unicode test data -->
	<import file="${TEST_ROOT}/TKG/scripts/getDependencies.xml"/>

	<!-- set global properties for this build -->
	<property name="DEST" value="${BUILD_ROOT}/functional/MBCS_Tests/codepoint" />

	<!--Properties for this particular build-->
	<property name="src" location="./src" />
	<property name="build" location="./bin" />
	
	<condition property="jdk8above" value="true">
		<not>
			<equals arg1="${JDK_VERSION}" arg2="8" />
		</not>
	</condition>

	<target name="init">
		<mkdir dir="${DEST}" />
		<mkdir dir="${build}" />
	</target>

	<target name="compile" depends="init" description="Using java${JDK_VERSION} to compile the source  " if="jdk8above">
		<echo>Ant version is ${ant.version}</echo>
		<echo>============COMPILER SETTINGS============</echo>
		<echo>===fork:				yes</echo>
		<echo>===executable:			${compiler.javac}</echo>
		<echo>===debug:				on</echo>
		<echo>===destdir:				${DEST}</echo>
		<javac srcdir="${src}" destdir="${build}" debug="true" fork="true" executable="${compiler.javac}" includeAntRuntime="false" encoding="ISO-8859-1">
			<src path="${src}" />
		</javac>
	</target>

	<target name="dist" depends="compile,copyData,extractUnicodeData" description="generate the distribution">
		<jar jarfile="${DEST}/codepoint.jar" filesonly="true">
			<fileset dir="${build}" />
			<fileset dir="${src}/../resources/" />
		</jar>
		<copy todir="${DEST}">
			<fileset dir="${src}/../" includes="*.sh" />
			<fileset dir="${src}/../" includes="*.bat" />
			<fileset dir="${src}/../" includes="expected.txt" />
			<fileset dir="../tools/" includes="*" />
		</copy>
	</target>
	
	<!-- Extract Unicode data: uses existing UnicodeVers.properties mapping -->
	<target name="extractUnicodeData" depends="getDependentLibs,init">
		<mkdir dir="${DEST}/data"/>
		
		<unzip src="${LIB_DIR}/UCD-10.0.0.zip" dest="${DEST}/data">
			<patternset><include name="UnicodeData.txt"/></patternset>
			<mapper type="glob" from="UnicodeData.txt" to="UnicodeData-10.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-11.0.0.zip" dest="${DEST}/data">
			<patternset><include name="UnicodeData.txt"/></patternset>
			<mapper type="glob" from="UnicodeData.txt" to="UnicodeData-11.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-12.0.0.zip" dest="${DEST}/data">
			<patternset><include name="UnicodeData.txt"/></patternset>
			<mapper type="glob" from="UnicodeData.txt" to="UnicodeData-12.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-12.1.0.zip" dest="${DEST}/data">
			<patternset><include name="UnicodeData.txt"/></patternset>
			<mapper type="glob" from="UnicodeData.txt" to="UnicodeData-12.1.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-13.0.0.zip" dest="${DEST}/data">
			<patternset><include name="UnicodeData.txt"/></patternset>
			<mapper type="glob" from="UnicodeData.txt" to="UnicodeData-13.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-14.0.0.zip" dest="${DEST}/data">
			<patternset><include name="UnicodeData.txt"/></patternset>
			<mapper type="glob" from="UnicodeData.txt" to="UnicodeData-14.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-15.0.0.zip" dest="${DEST}/data">
			<patternset><include name="UnicodeData.txt"/></patternset>
			<mapper type="glob" from="UnicodeData.txt" to="UnicodeData-15.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-15.1.0.zip" dest="${DEST}/data">
			<patternset><include name="UnicodeData.txt"/></patternset>
			<mapper type="glob" from="UnicodeData.txt" to="UnicodeData-15.1.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-16.0.0.zip" dest="${DEST}/data">
			<patternset><include name="UnicodeData.txt"/></patternset>
			<mapper type="glob" from="UnicodeData.txt" to="UnicodeData-16.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-17.0.0.zip" dest="${DEST}/data">
			<patternset><include name="UnicodeData.txt"/></patternset>
			<mapper type="glob" from="UnicodeData.txt" to="UnicodeData-17.0.0.txt"/>
		</unzip>
		
		<copy todir="${DEST}/data">
			<fileset dir="${LIB_DIR}">
				<include name="Unihan_IRGSources-*.txt"/>
			</fileset>
		</copy>
		
		<copy file="${LIB_DIR}/GB18030-2022.txt" todir="${DEST}/data" failonerror="false"/>
		
		<copy todir="${DEST}/data" failonerror="false">
			<fileset dir="${src}/../data/" includes="u32FF"/>
		</copy>
	</target>

	<target name="clean" depends="dist" description="clean up">
		<!-- Delete the ${build} directory trees -->
		<delete dir="${build}" />
	</target>

	<target name="build" >
		<antcall target="clean" inheritall="true" />
	</target>
</project>
