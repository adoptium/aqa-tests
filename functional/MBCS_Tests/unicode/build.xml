<project name="MBCS_Tests/unicode" default="build" basedir="." xmlns:if="ant:if">
	<description>
	MBCS_Tests/unicode
        </description>

	<!-- Import getDependencies.xml to enable downloading Unicode test data -->
	<import file="${TEST_ROOT}/TKG/scripts/getDependencies.xml"/>

	<!-- set global properties for this build -->
	<property name="DEST" value="${BUILD_ROOT}/functional/MBCS_Tests/unicode" />

	<!--Properties for this particular build-->
	<property name="src" location="./src" />
	<property name="build" location="./bin" />
	
	<target name="init">
		<mkdir dir="${DEST}" />
		<mkdir dir="${build}" />
	</target>

	<target name="compile" depends="init" description="Using java${JDK_VERSION} to compile the source  ">
		<echo>Ant version is ${ant.version}</echo>
		<echo>============COMPILER SETTINGS============</echo>
		<echo>===fork:				yes</echo>
		<echo>===executable:			${compiler.javac}</echo>
		<echo>===debug:				on</echo>
		<echo>===destdir:				${DEST}</echo>
		<javac srcdir="${src}" destdir="${build}" debug="true" fork="true" executable="${compiler.javac}" includeAntRuntime="false" encoding="ISO-8859-1">
			<src path="${src}" />
		</javac>
	</target>

	<target name="dist" depends="compile,extractUnicodeData" description="generate the distribution">
		<jar jarfile="${DEST}/unicode.jar" filesonly="true">
			<fileset dir="${build}" />
			<fileset dir="${src}/../resources/" />
		</jar>
		<copy todir="${DEST}">
			<fileset dir="${src}/../" includes="*.sh" />
			<fileset dir="${src}/../" includes="*.bat" />
			<fileset dir="../tools/" includes="*" />
		</copy>
	</target>
	
	<!-- Extract Unicode data: uses existing UnicodeVers.properties mapping -->
	<target name="extractUnicodeData" depends="getDependentLibs,init">
		<mkdir dir="${DEST}/data"/>
		
		<!-- Load JDK-to-Unicode version mapping -->
		<property file="${TEST_ROOT}/functional/MBCS_Tests/codepoint/resources/UnicodeVers.properties" prefix="unicode"/>
		
		<!-- Calculate version code (JDK 11 -> 11000000) -->
		<property name="jdk.version.code" value="${JDK_VERSION}000000"/>
		
		<!-- Get Unicode version for this JDK -->
		<property name="unicode.mapping" value="${unicode.${jdk.version.code}}"/>
		
		<!-- Validate mapping exists -->
		<fail message="No Unicode version mapping found for JDK ${JDK_VERSION} (code: ${jdk.version.code}). Please update UnicodeVers.properties.">
			<condition>
				<or>
					<not><isset property="unicode.mapping"/></not>
					<equals arg1="${unicode.mapping}" arg2="$${unicode.${jdk.version.code}}"/>
				</or>
			</condition>
		</fail>
		
		<!-- Extract version number (before comma) -->
		<loadresource property="unicode.version">
			<string value="${unicode.mapping}"/>
			<filterchain>
				<tokenfilter>
					<replaceregex pattern=",.*" replace=""/>
				</tokenfilter>
			</filterchain>
		</loadresource>
		
		<echo message="JDK ${JDK_VERSION} → Unicode ${unicode.version}"/>
		
		<!-- Extract 5 files for this version only -->
		<unzip src="${LIB_DIR}/UCD-${unicode.version}.zip" dest="${DEST}/data">
			<patternset>
				<include name="Blocks.txt"/>
				<include name="NormalizationTest.txt"/>
				<include name="PropertyValueAliases.txt"/>
				<include name="Scripts.txt"/>
				<include name="UnicodeData.txt"/>
			</patternset>
			<mapper type="regexp" from="^(.*)\.txt$$" to="\1-${unicode.version}.txt"/>
		</unzip>
		
		<!-- Copy special test files that remain in git (not from unicode.org) -->
		<copy todir="${DEST}/data">
			<fileset dir="${src}/../data/">
				<include name="README.txt"/>
				<include name="UnicodeData-GB18030-2022.txt"/>
				<include name="UnicodeData-u32FF.txt"/>
				<include name="UnicodeData-u32FF-jdk12.txt"/>
			</fileset>
		</copy>
	</target>

	<target name="clean" depends="dist" description="clean up">
		<!-- Delete the ${build} directory trees -->
		<delete dir="${build}" />
	</target>

	<target name="build" >
		<antcall target="clean" inheritall="true" />
	</target>
</project>
