<project name="MBCS_Tests/unicode" default="build" basedir=".">
	<description>
	MBCS_Tests/unicode
        </description>

	<import file="${TEST_ROOT}/TKG/scripts/getDependencies.xml"/>

	<!-- set global properties for this build -->
	<property name="DEST" value="${BUILD_ROOT}/functional/MBCS_Tests/unicode" />

	<!--Properties for this particular build-->
	<property name="src" location="./src" />
	<property name="build" location="./bin" />
	
	<target name="init">
		<mkdir dir="${DEST}" />
		<mkdir dir="${build}" />
	</target>

	<target name="compile" depends="init" description="Using java${JDK_VERSION} to compile the source  ">
		<echo>Ant version is ${ant.version}</echo>
		<echo>============COMPILER SETTINGS============</echo>
		<echo>===fork:				yes</echo>
		<echo>===executable:			${compiler.javac}</echo>
		<echo>===debug:				on</echo>
		<echo>===destdir:				${DEST}</echo>
		<javac srcdir="${src}" destdir="${build}" debug="true" fork="true" executable="${compiler.javac}" includeAntRuntime="false" encoding="ISO-8859-1">
			<src path="${src}" />
		</javac>
	</target>

	<target name="dist" depends="compile,extractUnicodeData" description="generate the distribution">
		<jar jarfile="${DEST}/unicode.jar" filesonly="true">
			<fileset dir="${build}" />
			<fileset dir="${src}/../resources/" />
		</jar>
		<copy todir="${DEST}">
			<fileset dir="${src}/../" includes="*.sh" />
			<fileset dir="${src}/../" includes="*.bat" />
			<fileset dir="../tools/" includes="*" />
		</copy>
	</target>
	
	<target name="extractUnicodeData" depends="getDependentLibs,init">
		<mkdir dir="${DEST}/data"/>
		
		<!-- Extract Unicode data files from UCD ZIP archives -->
		<unzip src="${LIB_DIR}/UCD-10.0.0.zip" dest="${DEST}/data">
			<patternset>
				<include name="Blocks.txt"/>
				<include name="NormalizationTest.txt"/>
				<include name="PropertyValueAliases.txt"/>
				<include name="Scripts.txt"/>
				<include name="UnicodeData.txt"/>
			</patternset>
			<mapper type="regexp" from="^(.*)\.txt$$" to="\1-10.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-11.0.0.zip" dest="${DEST}/data">
			<patternset>
				<include name="Blocks.txt"/>
				<include name="NormalizationTest.txt"/>
				<include name="PropertyValueAliases.txt"/>
				<include name="Scripts.txt"/>
				<include name="UnicodeData.txt"/>
			</patternset>
			<mapper type="regexp" from="^(.*)\.txt$$" to="\1-11.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-12.1.0.zip" dest="${DEST}/data">
			<patternset>
				<include name="Blocks.txt"/>
				<include name="NormalizationTest.txt"/>
				<include name="PropertyValueAliases.txt"/>
				<include name="Scripts.txt"/>
				<include name="UnicodeData.txt"/>
			</patternset>
			<mapper type="regexp" from="^(.*)\.txt$$" to="\1-12.1.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-13.0.0.zip" dest="${DEST}/data">
			<patternset>
				<include name="Blocks.txt"/>
				<include name="NormalizationTest.txt"/>
				<include name="PropertyValueAliases.txt"/>
				<include name="Scripts.txt"/>
				<include name="UnicodeData.txt"/>
			</patternset>
			<mapper type="regexp" from="^(.*)\.txt$$" to="\1-13.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-14.0.0.zip" dest="${DEST}/data">
			<patternset>
				<include name="Blocks.txt"/>
				<include name="NormalizationTest.txt"/>
				<include name="PropertyValueAliases.txt"/>
				<include name="Scripts.txt"/>
				<include name="UnicodeData.txt"/>
			</patternset>
			<mapper type="regexp" from="^(.*)\.txt$$" to="\1-14.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-15.0.0.zip" dest="${DEST}/data">
			<patternset>
				<include name="Blocks.txt"/>
				<include name="NormalizationTest.txt"/>
				<include name="PropertyValueAliases.txt"/>
				<include name="Scripts.txt"/>
				<include name="UnicodeData.txt"/>
			</patternset>
			<mapper type="regexp" from="^(.*)\.txt$$" to="\1-15.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-15.1.0.zip" dest="${DEST}/data">
			<patternset>
				<include name="Blocks.txt"/>
				<include name="NormalizationTest.txt"/>
				<include name="PropertyValueAliases.txt"/>
				<include name="Scripts.txt"/>
				<include name="UnicodeData.txt"/>
			</patternset>
			<mapper type="regexp" from="^(.*)\.txt$$" to="\1-15.1.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-16.0.0.zip" dest="${DEST}/data">
			<patternset>
				<include name="Blocks.txt"/>
				<include name="NormalizationTest.txt"/>
				<include name="PropertyValueAliases.txt"/>
				<include name="Scripts.txt"/>
				<include name="UnicodeData.txt"/>
			</patternset>
			<mapper type="regexp" from="^(.*)\.txt$$" to="\1-16.0.0.txt"/>
		</unzip>
		<unzip src="${LIB_DIR}/UCD-17.0.0.zip" dest="${DEST}/data">
			<patternset>
				<include name="Blocks.txt"/>
				<include name="NormalizationTest.txt"/>
				<include name="PropertyValueAliases.txt"/>
				<include name="Scripts.txt"/>
				<include name="UnicodeData.txt"/>
			</patternset>
			<mapper type="regexp" from="^(.*)\.txt$$" to="\1-17.0.0.txt"/>
		</unzip>
		
		<!-- Copy JDK-specific supplementary files from git (not in official Unicode releases) -->
		<copy todir="${DEST}/data">
			<fileset dir="${src}/../data/">
				<include name="README.txt"/>
				<include name="UnicodeData-GB18030-2022.txt"/>
				<include name="UnicodeData-u32FF.txt"/>
				<include name="UnicodeData-u32FF-jdk12.txt"/>
			</fileset>
		</copy>
	</target>

	<target name="clean" depends="dist" description="clean up">
		<!-- Delete the ${build} directory trees -->
		<delete dir="${build}" />
	</target>

	<target name="build" >
		<antcall target="clean" inheritall="true" />
	</target>
</project>
